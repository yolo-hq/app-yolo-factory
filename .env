# YOLO Factory — Local Development
# App ports: 9000 (API), 9001 (Worker health), 3001 (MCP), 3000 (Admin UI)
# Docker ports: PG_PORT (PostgreSQL), REDIS_PORT (Redis)

# Docker service ports (override in .env.local if conflict with other apps)
PG_PORT=5432
REDIS_PORT=6379

# App config (if you change PG_PORT/REDIS_PORT, update these too)
DATABASE_URL=postgresql://postgres@localhost:5432/yolo_factory?sslmode=disable
REDIS_URL=localhost:6379
